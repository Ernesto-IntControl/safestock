{
  "name": "safestock-backend",
  "version": "1.0.0",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "create-admin": "node scripts/createAdmin.js",
    "prisma": "npx prisma",
    "db:push": "npx prisma db push",
    "db:setup": "npm run db:push",
    "migrate:dev": "npx prisma migrate dev --name init",
    "db:reset": "npx prisma migrate reset --force"
  },
  "dependencies": {
    "express": "^4.18.2",
    "prisma": "^5.0.0",
    "@prisma/client": "^5.0.0",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "mysql2": "^3.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}